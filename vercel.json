{
  "version": 2,
  "builds": [
    {
      "src": "api/order.js",
      "use": "@vercel/node"
    },
    {
      "src": "order.html",
      "use": "@vercel/static"
    },
    {
      "src": "host_order_email.html",
      "use": "@vercel/static"
    },
    {
      "src": "visitor_order_email.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/order",
      "dest": "/api/order.js"
    },
    {
      "src": "/(.*)",
      "dest": "/order.html"
    }
  ]
}